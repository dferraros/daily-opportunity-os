{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Users\\ferra\\.local\\bin\\uv.exe run --no-sync python hooks/skill_router.py",
            "env": {
              "PYTHONPATH": "src",
              "PYTHONIOENCODING": "utf-8"
            }
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Users\\ferra\\.local\\bin\\uv.exe run --no-sync python hooks/inject_market_context.py",
            "env": {
              "PYTHONPATH": "src",
              "PYTHONIOENCODING": "utf-8"
            }
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Users\\ferra\\.local\\bin\\uv.exe run --no-sync python hooks/validate_required_fields.py",
            "env": {
              "PYTHONPATH": "src",
              "PYTHONIOENCODING": "utf-8"
            }
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Users\\ferra\\.local\\bin\\uv.exe run --no-sync python hooks/dedupe_opportunities.py",
            "env": {
              "PYTHONPATH": "src",
              "PYTHONIOENCODING": "utf-8"
            }
          },
          {
            "type": "command",
            "command": "C:\\Users\\ferra\\.local\\bin\\uv.exe run --no-sync python hooks/append_score_history.py",
            "env": {
              "PYTHONPATH": "src",
              "PYTHONIOENCODING": "utf-8"
            }
          },
          {
            "type": "command",
            "command": "C:\\Users\\ferra\\.local\\bin\\uv.exe run --no-sync python hooks/auto_rescore.py",
            "env": {
              "PYTHONPATH": "src",
              "PYTHONIOENCODING": "utf-8"
            }
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "geo-scout-.*",
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Users\\ferra\\.local\\bin\\uv.exe run --no-sync python hooks/preload_geo_context.py",
            "env": {
              "PYTHONPATH": "src",
              "PYTHONIOENCODING": "utf-8"
            }
          }
        ]
