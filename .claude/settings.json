    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Users\\ferra\\.local\\bin\\uv.exe run --no-sync python hooks/save_session_state.py",
            "env": {
              "PYTHONPATH": "src",
              "PYTHONIOENCODING": "utf-8"
            }
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Users\\ferra\\.local\\bin\\uv.exe run --no-sync python hooks/ensure_venezuela_section.py",
            "env": {
              "PYTHONPATH": "src",
              "PYTHONIOENCODING": "utf-8"
            }
          },
          {
            "type": "command",
            "command": "C:\\Users\\ferra\\.local\\bin\\uv.exe run --no-sync python hooks/track_machine_metrics.py",
            "env": {
              "PYTHONPATH": "src",
              "PYTHONIOENCODING": "utf-8"
            }
          },
          {
            "type": "command",
            "command": "C:\\Users\\ferra\\.local\\bin\\uv.exe run --no-sync python hooks/check_interview_quota.py",
