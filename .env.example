# AI Scorer — required for AI-powered dimension scoring (Step 2.5 of daily pipeline)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Notion API key for direct sync
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Phase 7: Parallel Intelligence Systems

# Awesome Skills / Composio integrations
COMPOSIO_API_KEY=your_composio_api_key_here
SCRAPINGBEE_API_KEY=your_scrapingbee_key_here
SERPAPI_KEY=your_serpapi_key_here
FIRECRAWL_API_KEY=your_firecrawl_key_here

# Google integrations (for googleads-automation, search-console-automation)
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_token_here
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service_account.json

# Notion (MCP handles auth, but keep ID references here)
NOTION_OPPORTUNITY_DB_ID=ad158a23-902c-4fed-9503-a8cffab29754
NOTION_DAILY_FEED_ID=243c2636-188c-4e7b-a9b2-520ca82b3834
NOTION_DEEP_DIVES_ID=e8079401-811e-4e9b-a43a-234bc03cce7b

# CoinGecko (free, no key needed — but note the rate limit)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# ─── FREE INTELLIGENCE STACK (Phase 07) ─────────────────────────
# All free tiers. Get keys at the URLs below.

# Serper.dev — real Google SERP results. 2,500 FREE queries/month (no CC required).
# Recommended: free for 6+ months at 30 runs/month. $0.001/query after free tier.
# Get key: https://serper.dev → sign up → API Key
SERPER_API_KEY=your_serper_api_key_here

# Exa.ai — semantic/neural search. Finds pain signals without exact keyword matches.
# 1,000 FREE queries/month. $0.007/query after free tier.
# Get key: https://exa.ai → dashboard → API Key
EXA_API_KEY=your_exa_api_key_here

# Reddit Official API — more reliable than .json scraping. ~$0.01/month at 30 runs.
# Register a "Script" app at: https://www.reddit.com/prefs/apps
# Set type to "script", redirect URI to http://localhost:8080
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# Tavily — research-grade search, free tier
# Get key: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Jina Reader — 10M free tokens, or use without key (20 req/min free)
# Get key: https://jina.ai (optional — works without key)
JINA_API_KEY=your_jina_api_key_here

# Brave Search — NOTE: free tier removed Feb 2026. $0.005/query.
# SKIP — Tavily ($0.003) gives equal or better results for less.
# BRAVE_API_KEY=your_brave_api_key_here

# Perplexity — research with citations, $0.005/query.
# SKIP — redundant with Tavily + Claude synthesis already in pipeline.
# PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Apify — thousands of scrapers, free tier
# Get key: https://apify.com → Settings → Integrations
APIFY_TOKEN=your_apify_token_here

# HN Algolia API — NO KEY NEEDED (free, no auth)
# Endpoint: https://hn.algolia.com/api/v1/search?query=...

# Google Trends via pytrends — NO KEY NEEDED
# Install: uv pip install pytrends
